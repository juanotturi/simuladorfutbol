package com.project.simuladorfutbol.service;

import java.util.Map;

public class ExactScoreMapper {
    private final Map<Integer, String> valueToScoreMap;

    public ExactScoreMapper(Map<Integer, String> valueToScoreMap) {
        this.valueToScoreMap = valueToScoreMap;
    }

    public String getScore(int value) {
        return valueToScoreMap.getOrDefault(value, "0-0");
    }
}
